#include <bits/stdc++.h>
using namespace std;

/*
🔥 Problem: Majority Element (n/2)

--------------------------------------------------
🧠 APPROACH: Boyer-Moore Voting Algorithm

👉 Key Idea:
If an element appears more than ⌊n/2⌋ times,
there can be ONLY ONE such element.

--------------------------------------------------
⚡ Phase 1: Find Candidate

We maintain:
- candidate
- count

Rules:
1. If count == 0 → pick new candidate
2. If same → increment count
3. Else → decrement count

👉 Why it works:
Majority element survives cancellation
of all other elements.

--------------------------------------------------
⚡ Phase 2 (Optional but Safe): Verify

In strict interview settings, always verify
candidate appears > n/2 times.

--------------------------------------------------
⏱️ Time Complexity: O(N)
⏱️ Space Complexity: O(1)

--------------------------------------------------
💡 Pattern:
Boyer-Moore Voting Algorithm
*/

class Solution {
public:
    int majorityElement(vector<int>& nums) {
        int candidate = 0;
        int count = 0;

        // Phase 1: Find candidate
        for (int num : nums) {
            if (count == 0) {
                candidate = num;
            }

            if (num == candidate) count++;
            else count--;
        }

        // Phase 2: Verify (important in general case)
        count = 0;
        for (int num : nums) {
            if (num == candidate) count++;
        }

        return (count > nums.size() / 2) ? candidate : -1;
    }
};
