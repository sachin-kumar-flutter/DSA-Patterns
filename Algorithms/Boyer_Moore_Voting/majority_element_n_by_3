#include <bits/stdc++.h>
using namespace std;

/*
🔥 Problem: Majority Element (n/3)

--------------------------------------------------
🧠 APPROACH: Boyer-Moore Voting Algorithm (Extended)

👉 Key Idea:
At most 2 elements can appear more than ⌊n/3⌋ times.

--------------------------------------------------
⚡ Phase 1: Find Candidates

We maintain:
- candidate1, candidate2
- count1, count2

Rules:
1. If same → increment count
2. If count becomes 0 → assign new candidate
3. Else → cancel both counts

👉 This works because:
Non-majority elements cancel out majority ones

--------------------------------------------------
⚡ Phase 2: Verify Candidates

We must re-count because:
Candidates are NOT guaranteed to be majority

--------------------------------------------------
⏱️ Time Complexity: O(N)
⏱️ Space Complexity: O(1)

--------------------------------------------------
💡 Pattern:
Boyer-Moore Voting Algorithm
*/

class Solution {
public:
    vector<int> findMajority(vector<int>& arr) {
        int candidate1 = 0, candidate2 = 1;
        int count1 = 0, count2 = 0;

        // Phase 1: Find candidates
        for (int num : arr) {
            if (num == candidate1) count1++;
            else if (num == candidate2) count2++;

            else if (count1 == 0) {
                candidate1 = num;
                count1 = 1;
            }
            else if (count2 == 0) {
                candidate2 = num;
                count2 = 1;
            }
            else {
                count1--;
                count2--;
            }
        }

        // Phase 2: Verify
        count1 = 0, count2 = 0;
        for (int num : arr) {
            if (num == candidate1) count1++;
            else if (num == candidate2) count2++;
        }

        vector<int> ans;
        int n = arr.size();

        if (count1 > n / 3) ans.push_back(candidate1);
        if (count2 > n / 3) ans.push_back(candidate2);

        return ans;
    }
};
